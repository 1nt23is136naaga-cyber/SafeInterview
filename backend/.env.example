# Copy this file to .env and fill in your values

# OpenAI API — used for LLM-based memorization evaluation
# If left empty, a heuristic mock evaluator runs instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Whisper model size: tiny | base | small | medium | large-v3
# 'base' is recommended for local dev. Use 'small' or higher for production accuracy.
WHISPER_MODEL_SIZE=base

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URIs to: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change_me_to_a_random_secret

# ── Storage (optional — leave empty for local uploads/) ───────────────────
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1

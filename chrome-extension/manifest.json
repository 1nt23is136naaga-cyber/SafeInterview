{
  "manifest_version": 3,
  "name": "AntiGravity — Interview Integrity Analyzer",
  "short_name": "AntiGravity",
  "version": "1.0.0",
  "description": "AI-powered interview integrity analysis for Google Meet. Detects behavioral anomalies and generates explainable reports.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "https://*.onrender.com/*",
    "https://*.vercel.app/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_page": "options/options.html",

  "web_accessible_resources": [
    {
      "resources": [
        "overlay/overlay.html",
        "overlay/overlay.css",
        "overlay/overlay.js",
        "lib/jspdf.umd.min.js",
        "icons/*.png"
      ],
      "matches": ["https://meet.google.com/*"]
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AntiGravity — Interview Integrity Analyzer"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

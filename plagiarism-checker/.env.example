COPYLEAKS_EMAIL=your_email@example.com
COPYLEAKS_API_KEY=your_copyleaks_api_key_here
PORT=3100

# The public URL where this server is reachable (Copyleaks calls this for webhooks)
# Use a tunneling tool like ngrok or cloudflared to expose localhost temporarily:
#   cloudflared tunnel --url http://localhost:3100
# Then paste the public URL below (no trailing slash):
PUBLIC_WEBHOOK_URL=https://your-public-url-here.trycloudflare.com
